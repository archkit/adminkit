{
  "name": "@green-spot/adminkit",
  "version": "0.0.0",
  "description": "管理画面向け CSS フレームワーク",
  "repository": {
    "type": "git",
    "url": "https://github.com/archkit/adminkit"
  },
  "exports": {
    "./css": {
      "style": "./dist/adminkit.min.css",
      "default": "./dist/adminkit.min.css"
    },
    "./js": "./dist/adminkit.min.js",
    "./theme-init": "./dist/theme-init.js"
  },
  "files": [
    "dist"
  ],
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ],
  "scripts": {
    "build:css": "lightningcss --bundle --minify --browserslist src/css/adminkit.css -o dist/adminkit.min.css",
    "build:js": "esbuild src/js/adminkit.js --bundle --minify --format=esm --target=es2022 --outfile=dist/adminkit.min.js",
    "build:init": "cp src/js/theme-init.js dist/theme-init.js",
    "build": "npm run build:css && npm run build:js && npm run build:init",
    "dev:css": "lightningcss --bundle --browserslist src/css/adminkit.css -o dist/adminkit.min.css",
    "dev:js": "esbuild src/js/adminkit.js --bundle --format=esm --target=es2022 --outfile=dist/adminkit.min.js",
    "dev:init": "cp src/js/theme-init.js dist/theme-init.js",
    "dev": "npm run dev:css && npm run dev:js && npm run dev:init",
    "serve": "php -S localhost:8080"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "lightningcss-cli": "^1.29.0"
  },
  "dependencies": {
    "lucide": "^1.8.0"
  }
}
